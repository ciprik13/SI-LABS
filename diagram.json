{
  "version": 1,
  "author": "Lab 5.2 – Dual Actuator + Potentiometer",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-arduino-mega",
      "id": "mega",
      "top": 200,
      "left": 0,
      "attrs": {}
    },

    { "type": "wokwi-lcd1602", "id": "lcd",
      "top": 0, "left": 300,
      "attrs": { "pins": "i2c", "address": "0x27" } },

    { "type": "wokwi-potentiometer", "id": "pot",
      "top": 0, "left": 560,
      "attrs": { "value": "0" } },

    { "type": "wokwi-resistor", "id": "r_red",    "top": 80,  "left": 540, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r_green",  "top": 120, "left": 540, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r_yellow", "top": 160, "left": 540, "attrs": { "value": "220" } },

    { "type": "wokwi-led", "id": "led_red",    "top": 80,  "left": 620, "attrs": { "color": "red"    } },
    { "type": "wokwi-led", "id": "led_green",  "top": 120, "left": 620, "attrs": { "color": "green"  } },
    { "type": "wokwi-led", "id": "led_yellow", "top": 160, "left": 620, "attrs": { "color": "yellow" } },

    { "type": "wokwi-relay-module", "id": "relay",
      "top": 260, "left": 540, "attrs": {} },

    { "type": "wokwi-l298n", "id": "l298n",
      "top": 360, "left": 520, "attrs": {} },

    { "type": "wokwi-dc-motor", "id": "motor",
      "top": 480, "left": 560, "attrs": { "rpm": "200" } }
  ],
  "connections": [
    ["mega:GND.1", "mega:GND.2", "black", []],

    ["mega:20",    "lcd:SDA",    "green",  []],
    ["mega:21",    "lcd:SCL",    "yellow", []],
    ["mega:5V",    "lcd:VCC",    "red",    []],
    ["mega:GND.1", "lcd:GND",    "black",  []],

    ["pot:VCC",    "mega:5V",    "red",    []],
    ["pot:GND",    "mega:GND.1", "black",  []],
    ["pot:SIG",    "mega:A0",    "orange", []],

    ["mega:9",      "r_red:1",     "red",    []],
    ["r_red:2",     "led_red:A",   "red",    []],
    ["led_red:C",   "mega:GND.1",  "black",  []],

    ["mega:12",     "r_green:1",   "green",  []],
    ["r_green:2",   "led_green:A", "green",  []],
    ["led_green:C", "mega:GND.1",  "black",  []],

    ["mega:11",     "r_yellow:1",   "yellow", []],
    ["r_yellow:2",  "led_yellow:A", "yellow", []],
    ["led_yellow:C","mega:GND.1",   "black",  []],

    ["mega:13",    "relay:IN",    "orange", []],
    ["mega:5V",    "relay:VCC",   "red",    []],
    ["mega:GND.1", "relay:GND",   "black",  []],

    ["mega:10",    "l298n:ENA",      "purple", []],
    ["mega:8",     "l298n:IN1",      "blue",   []],
    ["mega:7",     "l298n:IN2",      "blue",   []],
    ["mega:5V",    "l298n:5V",       "red",    []],
    ["mega:GND.1", "l298n:GND",      "black",  []],

    ["l298n:MOTOR_A1", "motor:1",  "orange", []],
    ["l298n:MOTOR_A2", "motor:2",  "orange", []]
  ],
  "serialMonitor": {
    "display": "terminal",
    "newline": "lf"
  }
}